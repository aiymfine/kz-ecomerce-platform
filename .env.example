# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopbuilder
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Kaspi Pay (optional for dev)
KASPI_PAY_MERCHANT_ID=
KASPI_PAY_SECRET_KEY=

# Halyk Bank (optional for dev)
HALYK_BANK_CLIENT_ID=
HALYK_BANK_CLIENT_SECRET=

# Shipping
CHOCO_API_KEY=
KAZPOST_API_KEY=

# Email — AgentMail (https://agentmail.to)
AGENTMAIL_API_KEY=am_...
AGENTMAIL_INBOX_ID=your-inbox@agentmail.to
# Legacy SMTP vars (fallback, used by standalone workers)
SMTP_HOST=smtp.agentmail.to
SMTP_PORT=465
SMTP_USER=your-inbox@agentmail.to
SMTP_PASSWORD=am_...

# App URL (for password reset links, etc.)
APP_URL=http://localhost:3001

# SSL
LETSENCRYPT_EMAIL=admin@shopbuilder.kz
