# ===== Environment =====
NODE_ENV=development
ENVIRONMENT=development
PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=3000

# ===== Database (PostgreSQL 15+) =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopbuilder
DATABASE_POOL_SIZE=20
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shopbuilder

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT Authentication =====
JWT_SECRET_KEY=change-this-to-a-64-char-secret-in-production
JWT_REFRESH_SECRET_KEY=change-this-to-a-different-64-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== Email Service (Gmail SMTP / SendGrid / AgentMail) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=noreply@shopbuilder.kz
EMAIL_API_KEY=your-email-api-key

# ===== Payment: Kaspi Pay =====
KASPI_PAY_MERCHANT_ID=
KASPI_PAY_SECRET_KEY=

# ===== Payment: Halyk Bank =====
HALYK_BANK_CLIENT_ID=
HALYK_BANK_CLIENT_SECRET=

# ===== Shipping =====
CHOCO_API_KEY=
KAZPOST_API_KEY=

# ===== App URL (for password reset links, etc.) =====
APP_URL=http://localhost:3001

# ===== SSL =====
LETSENCRYPT_EMAIL=admin@shopbuilder.kz
