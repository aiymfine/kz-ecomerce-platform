{
  "info": {
    "name": "KZ E-Commerce Platform — Defence Demo",
    "description": "Complete API collection for the KZ E-Commerce Platform, organised for a live defence demo. Run folder 0 (Setup) first to obtain tokens, then explore each module.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001/api"
    },
    {
      "key": "merchant_email",
      "value": "merchant@shopbuilder.kz"
    },
    {
      "key": "merchant_token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "customer_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "store_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "0. Setup (run these first)",
      "description": "⚠️ Run these requests in order to bootstrap the demo environment. Tokens are auto-saved into collection variables.",
      "item": [
        {
          "name": "1. Register Merchant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@shopbuilder.kz\",\n  \"password\": \"merchant123\",\n  \"name\": \"Aibek\",\n  \"businessName\": \"Demo Shop\"\n}"
            }
          }
        },
        {
          "name": "2. Login Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('merchant_token', res.accessToken);",
                  "}",
                  "if (res.refreshToken) {",
                  "  pm.collectionVariables.set('refresh_token', res.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{merchant_email}}\",\n  \"password\": \"merchant123\"\n}"
            }
          }
        },
        {
          "name": "3. Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('admin_token', res.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/admin/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "admin",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopbuilder.kz\",\n  \"password\": \"admin123456\"\n}"
            }
          }
        },
        {
          "name": "4. Approve Merchant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/merchants/1/approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "merchants",
                "1",
                "approve"
              ]
            }
          }
        },
        {
          "name": "5. Create Store",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchant_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/stores",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "stores"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Store\",\n  \"subdomain\": \"demo\",\n  \"description\": \"Defence demo store\"\n}"
            }
          }
        }
      ]
    },
