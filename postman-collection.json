{
  "info": {
    "name": "KZ E-Commerce Platform — Defence Demo",
    "description": "Complete API collection for the KZ E-Commerce Platform, organised for a live defence demo. Run folder 0 (Setup) first to obtain tokens, then explore each module.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "merchant_email", "value": "merchant1@example.com" },
    { "key": "merchant_token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "customer_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "store_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "variant_id", "value": "" },
    { "key": "warehouse_id", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "webhook_id", "value": "" },
    { "key": "order_number", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "promo_code", "value": "" }
  ],
  "item": [
    {
      "name": "0. Setup (run these first)",
      "description": "Run these requests in order to obtain tokens and create test data. Tokens and IDs are auto-saved into collection variables.",
      "item": [
        {
          "name": "1. Login Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('merchant_token', res.data.accessToken);",
                  "  pm.collectionVariables.set('merchant_email', 'merchant1@example.com');",
                  "}",
                  "if (res.data?.refreshToken) {",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant1@example.com\",\n  \"password\": \"Merchant123\"\n}"
            }
          }
        },
        {
          "name": "2. Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('admin_token', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/admin/login", "host": ["{{base_url}}"], "path": ["auth", "admin", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopbuilder.kz\",\n  \"password\": \"Admin123456\"\n}"
            }
          }
        },
        {
          "name": "3. Get My Stores (save store_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (Array.isArray(res) && res.length > 0) {",
                  "  pm.collectionVariables.set('store_id', String(res[0].id));",
                  "} else if (res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('store_id', String(res.data[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores", "host": ["{{base_url}}"], "path": ["stores"] }
          }
        }
      ]
    },
    {
      "name": "1. Authentication",
      "description": "Merchant authentication — register, login, email verification, password reset, token refresh, logout, and profile.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your-email@gmail.com\",\n  \"password\": \"Merchant123\",\n  \"name\": \"New Merchant\",\n  \"businessName\": \"New Store\",\n  \"phone\": \"+7 777 000 0000\"\n}"
            }
          },
          "description": "Register a new merchant account. A 6-digit verification code will be sent to the email. Use your real email to receive the code."
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{merchant_email}}\",\n  \"password\": \"Merchant123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/verify-email", "host": ["{{base_url}}"], "path": ["auth", "verify-email"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your-email@gmail.com\",\n  \"code\": \"PASTE_6_DIGIT_CODE_FROM_EMAIL\"\n}"
            }
          },
          "description": "Verification code is sent to your email via AgentMail. Register a new account first, then check your inbox for the 6-digit code. Does NOT work with pre-verified seed accounts."
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/resend-verification", "host": ["{{base_url}}"], "path": ["auth", "resend-verification"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newmerchant@test.com\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{merchant_email}}\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_TOKEN_FROM_RESET_EMAIL\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          },
          "description": "Call Forgot Password first — a reset token is sent to your email via AgentMail. Paste the token from the email here."
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "2. Admin",
      "description": "Platform admin endpoints. All require admin_token. Merchant IDs come from List Merchants.",
      "item": [
        {
          "name": "List Merchants",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const merchants = res.data || res;",
                  "if (Array.isArray(merchants) && merchants.length > 0) {",
                  "  pm.collectionVariables.set('merchant_id', String(merchants[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/merchants", "host": ["{{base_url}}"], "path": ["admin", "merchants"] }
          }
        },
        {
          "name": "Get Merchant Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/merchants/{{merchant_id}}", "host": ["{{base_url}}"], "path": ["admin", "merchants", "{{merchant_id}}"] }
          }
        },
        {
          "name": "Approve Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/merchants/{{merchant_id}}/approve", "host": ["{{base_url}}"], "path": ["admin", "merchants", "{{merchant_id}}", "approve"] }
          }
        },
        {
          "name": "Suspend Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/merchants/{{merchant_id}}/suspend", "host": ["{{base_url}}"], "path": ["admin", "merchants", "{{merchant_id}}", "suspend"] }
          }
        },
        {
          "name": "Reactivate Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/merchants/{{merchant_id}}/activate", "host": ["{{base_url}}"], "path": ["admin", "merchants", "{{merchant_id}}", "activate"] }
          }
        },
        {
          "name": "List Stores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/stores", "host": ["{{base_url}}"], "path": ["admin", "stores"] }
          }
        },
        {
          "name": "Platform Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/analytics", "host": ["{{base_url}}"], "path": ["admin", "analytics"] }
          }
        },
        {
          "name": "Audit Log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/audit-log", "host": ["{{base_url}}"], "path": ["admin", "audit-log"] }
          }
        },
        {
          "name": "Queue Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/queue/status", "host": ["{{base_url}}"], "path": ["admin", "queue", "status"] }
          }
        }
      ]
    },
    {
      "name": "3. Stores",
      "description": "Merchant store management. All require merchant_token. store_id is auto-set from Setup.",
      "item": [
        {
          "name": "List My Stores",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const stores = Array.isArray(res) ? res : (res.data || []);",
                  "if (stores.length > 0) {",
                  "  pm.collectionVariables.set('store_id', String(stores[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores", "host": ["{{base_url}}"], "path": ["stores"] }
          }
        },
        {
          "name": "Create Store",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('store_id', String(res.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores", "host": ["{{base_url}}"], "path": ["stores"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My KZ Store\",\n  \"subdomain\": \"my-kz-store\",\n  \"currency\": \"KZT\"\n}"
            }
          }
        },
        {
          "name": "Get Store",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}"] }
          }
        },
        {
          "name": "Update Store",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Store\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Products",
      "description": "Merchant product management. All require merchant_token + store_id.",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('product_id', String(res.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/products", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"T-Shirt\",\n  \"description\": \"Cotton t-shirt\",\n  \"sku\": \"TSH-001\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/products", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "products"] }
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "products", "{{product_id}}"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "products", "{{product_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated T-Shirt\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Generate Variants",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const variants = res.data || [];",
                  "if (variants.length > 0) {",
                  "  pm.collectionVariables.set('variant_id', String(variants[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/products/{{product_id}}/variants", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "products", "{{product_id}}", "variants"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sizes\": [\"S\", \"M\", \"L\"],\n  \"colors\": [\"Black\", \"White\"],\n  \"basePriceTiyin\": 15990000,\n  \"compareAtPriceTiyin\": 19990000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Categories",
      "description": "Merchant category management. All require merchant_token + store_id.",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('category_id', String(res.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/categories", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T-Shirts\",\n  \"slug\": \"tshirts\",\n  \"path\": \"/tshirts\",\n  \"depth\": 1,\n  \"sortOrder\": 1\n}"
            }
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/categories", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "categories"] }
          }
        }
      ]
    },
    {
      "name": "6. Warehouses",
      "description": "Merchant warehouse management. All require merchant_token + store_id.",
      "item": [
        {
          "name": "Create Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('warehouse_id', String(res.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/warehouses", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "warehouses"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Almaty Warehouse\",\n  \"address\": \"Abai Ave 50\",\n  \"city\": \"Almaty\",\n  \"latitude\": 43.2389,\n  \"longitude\": 76.8896\n}"
            }
          }
        },
        {
          "name": "List Warehouses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/warehouses", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "warehouses"] }
          }
        }
      ]
    },
    {
      "name": "7. Inventory",
      "description": "Merchant inventory management. All require merchant_token + store_id.",
      "item": [
        {
          "name": "Set Inventory",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchant_token}}" }
            ],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/inventory", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "inventory"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variant_id\": {{variant_id}},\n  \"warehouse_id\": {{warehouse_id}},\n  \"quantity_available\": 100,\n  \"low_stock_threshold\": 5\n}"
            }
          }
        },
        {
          "name": "List Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/inventory", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "inventory"] }
          }
        },
        {
          "name": "Nearest Warehouse",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/inventory/nearest-warehouse?variant_ids={{variant_id}}&customer_latitude=43.2389&customer_longitude=76.8896", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "inventory", "nearest-warehouse"] }
          }
        }
      ]
    },
    {
      "name": "8. Cart",
      "description": "Customer cart operations. Requires authentication.",
      "item": [
        {
          "name": "Get / Create Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchant_token}}" }],
